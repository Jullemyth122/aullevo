{
  "manifest_version": 3,
  "name": "Aullevo - AI Form Filler",
  "version": "1.1.0",
  "description": "Auto-fill forms using your resume data powered by Gemini AI. Press Ctrl+M to open the sidebar!",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "Activate the extension"
    }
  },
  "action": {
    "default_title": "Aullevo — Toggle Sidebar (Ctrl+M)"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["pdf.worker.min.js", "assets/content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}

