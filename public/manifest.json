{
  "manifest_version": 3,
  "name": "Aullevo - AI Form Filler",
  "version": "1.1.0",
  "description": "Auto-fill forms using your resume data powered by Gemini AI. Press Ctrl+M to open the sidebar!",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+M"
      },
      "description": "Activate the extension"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Aullevo — Toggle Sidebar (Ctrl+M)",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "host_permissions": [
    "https://www.messenger.com/*",
    "https://www.facebook.com/*",
    "https://mail.google.com/*",
    "https://chat.google.com/*",
    "https://hangouts.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pdf.worker.min.js",
        "assets/content.css",
        "icon16.png",
        "icon48.png",
        "icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}


